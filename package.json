{
  "name": "kylin-arm64-64kb-page-size-mcp",
  "version": "0.1.0",
  "description": "Offline MCP ECharts SSE server using SVG SSR and rsvg-convert PNG rendering for Kylin ARM64 64KB page-size hosts.",
  "type": "module",
  "bin": {
    "kylin-mcp-echarts": "src/index.js"
  },
  "scripts": {
    "start": "node src/index.js --transport sse --port 7003",
    "smoke": "node scripts/smoke-render.js",
    "build:kylin-arm64-tar": "bash scripts/build-kylin-arm64-tar.sh"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "echarts": "6.1.0",
    "express": "5.1.0",
    "zod": "3.25.76"
  },
  "engines": {
    "node": ">=20"
  }
}
